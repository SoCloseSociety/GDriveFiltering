# ============================================================
# GDriveFiltering -- configuration
# Copier en .env et adapter. NE JAMAIS committer .env.
# ============================================================

# --- Google OAuth ---------------------------------------------------
# Create an OAuth client (type "Desktop app") in Google Cloud Console with the
# Google Drive API enabled, then paste its ID/secret here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: reuse creds from other projects' .env files if the two above are
# empty (colon-separated paths). Leave empty to disable.
# GDRIVE_BORROW_ENV=/path/to/other/.env:/path/to/another/.env

# Port du serveur loopback pour le consent OAuth.
# Le redirect http://localhost:<PORT>/ doit être autorisé sur le client OAuth
# (clients Desktop: automatique ; clients Web: à ajouter dans la console GCP).
OAUTH_LOOPBACK_PORT=8765

# Scope Drive. read-only par défaut (SÉCURITÉ -- ne jamais élargir sans raison).
# Valeurs possibles: readonly | full
DRIVE_SCOPE=readonly

# --- Destinations de backup ----------------------------------------
# Miroir principal (sur le Mac).
BACKUP_ROOT=./backups
# Miroir secondaire (disque dur externe). Laisser vide si aucun.
BACKUP_MIRROR_EXT=

# Marge d'espace libre exigée à la destination avant extraction (en Go).
DISK_SAFETY_MARGIN_GB=5

# Nombre de téléchargements parallèles (bande passante vs quota API Google).
DOWNLOAD_WORKERS=8

# --- Export des fichiers Google natifs ------------------------------
# office | pdf  (Docs->docx/pdf, Sheets->xlsx/pdf, Slides->pptx/pdf)
GOOGLE_EXPORT_FORMAT=office

# --- Ollama (dédup sémantique, filtrage LLM local) ------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_LLM_MODEL=qwen2.5:7b
